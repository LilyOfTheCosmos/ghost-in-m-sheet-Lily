:: IroncladHallway [hauntedhouse IroncladHallway] {"position":"2700,400","size":"100,100"}
<<nobr>>
<div class="room">
	<div class="room-wrapper">
		<div class="content">
          	<div id="actionironcladHallway" class="action">
				
          	</div>
        </div>
        
		<div class="footer">
        	<div class="footertools">
         	<<toolCard "assets/img/emf.png" "ironcladHallwayPicEMF" "searchEMFHallwayIronclad">>
         	<<toolCard "assets/img/glass.png" "actionironcladHallwayPicPlasm" "searchPlasmHallwayIronclad">>
         	<<toolCard "assets/img/gwb.png" "actionironcladHallwayPicGWB" "searchGwbHallwayIronclad">>
         	<<toolCard "assets/img/spiritbox.png" "actionironcladHallwayPicSB" "searchSbHallwayIronclad">>
         	<<toolCard "assets/img/thermometr.png" "actionironcladHallwayPicThermometr" "searchThermometrHallwayIronclad">>
         	<<toolCard "assets/img/uvl.png" "actionironcladHallwayPicUVL" "searchUvlHallwayIronclad">>
            <<companionCard>>
            <div class="footer-card footer-light">
            	<span class="cursedHuntLinkDisable"><<link [img[assets/img/lighton.png][IroncladHallway]]>><<set $hallway.background to 1>><</link>>
             <<link [img[assets/img/lightoff.png][IroncladHallway]]>><<set $hallway.background to 2>><</link>>
			<<if $mc.lust gte 80 and $weakenTheGhostQuest and $isWeakenGhost neq 1>> 
<<link [img[assets/img/hearth.png][minigame]]>>
<<set $minigameVideo to "start">>
<<set $ghostOrgasmMeter to 0>>
<<set $mcOrgasmMeter to 0>><</link>>
<</if>></span>
            </div>
         </div>
         <div class="footeraction">
			@@.adaptiveLink;<<link "Reception" "IroncladReception">>
<<includeTimeEventHunt>><<set $stepCount += 1>><</link>>@@   
			@@.adaptiveLink;<<link "Kitchen" "IroncladKitchen">>
<<includeTimeEventHunt>><<set $stepCount += 1>><</link>>@@  
			@@.adaptiveLink;<<link "BlockA" "IroncladBlockA">>
<<includeTimeEventHunt>><<set $stepCount += 1>><</link>>@@  
			@@.adaptiveLink;<<link "BlockB" "IroncladBlockB">>
<<includeTimeEventHunt>><<set $stepCount += 1>><</link>>@@  
	<br>
			@@.adaptiveLink;<<link "Leave" "Ironclad Prison">>
<</link>>@@  
		 </div>
		</div>
	</div>
</div>
<</nobr>>


