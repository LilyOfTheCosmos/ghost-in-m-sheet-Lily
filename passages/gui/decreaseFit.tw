:: decreaseFit {"position":"3050,1425","size":"100,100"}
<<nobr>>
<<set $previousFit = $mc.fit>>
<<set $mc.fit -= 1>>

<<if $previousFit % 5 == 0 and $previousFit > 0>>
    <<set $mc.beauty -= 1>>
<</if>>

<<set $mc.fit = Math.max(0, $mc.fit)>>
<<set $mc.fit = Math.min(100, $mc.fit)>>
<<set $mc.beauty = Math.min(100, Math.max(0, $mc.beauty))>>
<<set $previousFit = $mc.fit>>
[[GymInside]] 
<</nobr>>


