}

.companion-image {
  	width: 70%;
    border: 3px solid #007BFF; 
    border-radius: 8px; 
    padding: 5px; 
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2); 
    cursor: pointer; 
    transition: all 0.3s ease;
 }
.companion-image:hover {
    border-color: #0056b3; 
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
}
.companion-imageSucceeded {
	width: 70%;
    border: 3px solid #FF69B4;
    border-radius: 8px;
    padding: 5px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
    cursor: pointer;
    transition: all 0.3s ease;
}

.companion-imageSucceeded:hover {
    border-color: #FF1493; 
    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.3);
}

.toolsTextCentered {
	margin-left: 15%;
  	 -webkit-text-stroke: 1px black;
}

.flexwrapperCompanionMain {
    display: flex;
    align-content: stretch;
    height: 100%;
    row-gap: 10px;
    justify-content: space-between;
    align-items: center;
}
.companionImageMain {
	flex: 1;
	min-width: 40%;
}

