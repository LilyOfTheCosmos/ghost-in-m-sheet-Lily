<<elseif $tshirtState eq "not worn" and $pantiesState eq "worn" and ($jeansState neq "worn" and $skirtState neq "worn" and $shortsState neq "worn")>>
<<if $mc.exhib lte 4>>
<<if $braState eq "worn">>
<<set _videoList to [
	{type: "image", src: "naked/5.png"},
	{type: "image", src: "naked/6.png"},
