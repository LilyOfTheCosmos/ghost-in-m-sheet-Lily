.right {
  	display: inline-block;
	background-color: green;
  	border-radius: 30%;
}

.room {
   	position: absolute;
    top: 0;
  	height: 100vh;
	overflow-x: hidden;
	display: flex;
}
.room-wrapper {
    line-height: 1;
  	width: 100%;
  	display: flex;
  	position: relative;
  	flex-direction: column;
  	box-sizing: border-box;
 	padding-bottom: 5%;
}

.content {
	height: calc(100%/1.25);
    max-width: 80%;
  	overflow: hidden;
    box-sizing: border-box;
  	padding: 0;
}

.footer {
	display:flex;
  	align-items: flex-end;
  	max-height: 20%;
}

.footer-card {
	display: flex;
    flex-wrap: wrap;
    flex-direction: column;
	width: calc(100% / 7);
}

.footertools {
	display:flex;
  	width: 80%;
  	align-items: center;

}

.footeraction {
  	line-height: 1.6;
  	width: 20%;
	display: flex;
    flex-direction: column;
}

.cardlink {
	line-height: 1;
  	height: 30px;
  	font-size: 80%;
}

.hidden {
	visibility: hidden;
}

.visible {
	visibility: visible;
}

.UVLimg {
  	max-width: 100%;
    height: auto; 
  	display: block;
}

.action {
	display:flex;
  	flex-direction: column;
  	 align-items: center;
}

.GWBimgs {
	max-width: 50%;
}

.mc-action {
        background-color: #ffe6f2; 
        padding: 10px; 
        border-radius: 10px; 
        border: 2px solid #ff66b2; 
        font-family: 'Arial', sans-serif; 
        font-size: 18px; 
        color: #99004d; 
        text-align: center; 
    }

.spiritbox-container { 
    padding: 10px;
    border-radius: 10px;
    border: 2px solid #333; 
    margin-bottom: 10px;
    display: flex;
    flex-direction: column;
  	font-weight: bold;
}

.spiritbox-question {
    font-weight: bold;
    color: #ff3366; 
}

.spiritbox-answer {
    font-style: italic;
    color: #3399ff; 
    margin-top: 5px;
}

.spiritbox-no-response {
    color: white; 
    font-style: italic;
}

.location {
	font-size: 1.5em;
  	font-style: italic;
  	color: #f2f5f7;
  	text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
}

.mc-speech {
	color:#ff99dd;
  	text-decoration: none;
  	  text-shadow:-1px -1px 0 #000,  1px -1px 0 #000,-1px  1px 0 #000,1px  1px 0 #000;
}

.mc-speech:hover {
	
  	text-decoration: none;
  	text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.5);
}

.mc-speech a {
	color:#FF1493;
  	font-style: italic;
  	text-decoration: none;
}

.mc-speech a:hover {
	color:#f663b2;
  	font-style: italic;
  	text-decoration: none;
  	text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.5);
}


.mc-speechLink a {
	color:#FF1493;
  	font-style: italic;
  	text-decoration: none;
}

.mc-speechLink {
	color:#FF1493;
  	font-style: italic;
  	text-decoration: none;
}

.mc-thoughts {
  color: #eee;
  font-style: italic;
  text-decoration: none;
  text-shadow:-1px -1px 0 #000,  1px -1px 0 #000,-1px  1px 0 #000,1px  1px 0 #000;
  
}

.mc-thoughts a {
  color: #777777;
  font-style: italic;
  text-decoration: none;
}

.mc-thoughtsLink {
  color: #777777;
  font-style: italic;
  text-decoration: none;
}

.notmc-speech {
	color: #3486eb;
  	text-decoration: none;
  	  text-shadow:-1px -1px 0 #000,  1px -1px 0 #000,-1px  1px 0 #000,1px  1px 0 #000;
}
.notmc-speech a {
  font-size:1.1em;
  color: #0036ce;
  font-style: italic;
  text-decoration: none;
}

.notmc-speechLink {
  color: #114d96;
  font-style: italic;
}

.notmc-speechLink:hover{
  color: #3486eb;
  font-style: italic;
  text-decoration: none;
}


.priceAmount {
  font-weight: bold;
	color:#17B169;
  	font-size:1.7em;
  -webkit-text-stroke: 1px black;
  text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.8);
  vertical-align: middle;
 
}

.buyItemLink a {
 	color: black;
  	background-color: #f0f0f0;
  	padding: 1px 15px;
  	border-radius: 30%;
}

.address-item {
	font-size: 1.4em;
  	font-style: italic;
 	font-weight: bold;
}

.order-container {
  display: flex;
  align-items: center;
  gap: 0.5em;
}

.adaptiveLink a {
  	font-weight: bold;
	color: #3498db;
    text-decoration: none;
    transition: color 0.3s, border-color 0.3s;

  text-shadow:-1px -1px 0 #000,  1px -1px 0 #000,-1px  1px 0 #000,1px  1px 0 #000;
}

.movebtn a {
  	font-size: 1.2em;
  	font-weight: bold;
	color: #3498db;
    text-decoration: none;
    transition: color 0.3s, border-color 0.3s;
	-webkit-text-stroke: 1px black;
  	text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
}

.movebtn a:hover {
	color: #91a5c2;
	transition: color 0.3s, border-color 0.3s;
	-webkit-text-stroke: 1px black;
  	text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
}

.itemwrapper {
  	display: flex;
    flex-wrap: wrap;
    gap: 5%;
}

.footer-light img {
	width: 30%;

	margin: 1px;	
}
.footer-light {
  display: inline-block;
}


#time {
  font-family: "Kode Mono", sans-serif;
    font-size: 20px;
    color: #333;
    background-color: #eee;
    padding: 10px;
  	width: 100px;
    border-radius: 5px;
    display: inline-block;
    text-align: center;
    box-sizing: border-box;
}

.nightTime {
  filter: brightness(0.7);
}

.evidenceImgs {
    width: auto;
    max-height: 67vh;
}

.notFound-container { 
    padding: 10px;
    border-radius: 10px;
    border: 2px solid white; 
    margin-bottom: 10px;
    display: flex;
    flex-direction: column;
}

.evidenceText {
	font-size: 2.2vh;
}

#ghostTypeSelected {
  overflow-y: auto;
}

.evidenceFlex {
	display:flex;
  	flex-direction: column;
}

.evidenceWrapper {
	display:flex;
	border: 2px solid #000;
  	padding: 10px;
  	
}

.evidenceDesc {
	align-self:center;
  	flex-basis: 70%;
}

.evidenceCardIcon {
	flex-basis: 20%;
}

#bgPC {
  display: block;
  width: 100%;
  height: auto;
}

.iconContainer {
  position: absolute;
  top: 25%;
  left: 30%;
  transform: translate(-30%, -25%);
  width: calc(100% - 40px); 
  height: calc(100% - 40px); 
  display: flex;
  flex-wrap: wrap; 
  gap: 10px;
  box-sizing: border-box;
  padding: 20px;
  justify-content: flex-start; 
  align-items: flex-start;
}

.iconContainer a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc(20% - 10px);
  max-width: 100px; 
  height: auto; 
}

.iconContainer img {
  width: 100%; 
  height: auto; 
  max-width: 100%; 
  max-height: 100%; 
  display: block;
  border-radius:50%;
}

.wrapperPC {
  position: relative;
  width: 100%;
  max-width: 1000px;
  overflow: hidden; 
}

.iconPC {
  border-radius:50%;
  margin-bottom: 1%; 
}

 .room-container {
    position: relative;
   	padding-bottom: 66.67%;
    width: 100%;
    background-image: url('assets/img/hotelRoom.jpeg');
    background-size: cover;
   	background-position: center;
   	overflow: hidden;
  }
  .trash {
    position: absolute;
    cursor: pointer;
    width: 5%;
    height: auto;
  }
  #cleanup-message {
    display: none;
    margin-top: 20px;
    font-weight: bold;
    color: green;
  }

.displayCentredImgs {
    width: auto;
    max-height: 70vh;
	display: block;
    margin-left: auto;
    margin-right: auto;
}

.displayCentredImgsEvent {
    width: auto;
    max-height: 61vh;
	display: block;
    margin-left: auto;
    margin-right: auto;
}

.backbtn a {
  	border-radius: 5px;
  	padding: 10px; 
  	background-color: rgba(255, 255, 255, 0.8);
  	font-size: 1.2em;
  	font-weight: bold;
	color: #428ec2;
    text-decoration: none;
    transition: color 0.3s, border-color 0.3s;
	-webkit-text-stroke: 0.7px black;
  	text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.3);
}

.backbtn a:hover {
	color: #5dade2;
	transition: color 0.3s, border-color 0.3s;
	-webkit-text-stroke: 1px black;
  	text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
}


