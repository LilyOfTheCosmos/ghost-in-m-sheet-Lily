}

.flexwrapperCompanionMainInfo {
    display: flex;
    align-content: stretch;
    height: 100%;
    row-gap: 10px;
    justify-content: space-between;
}

.boldText {
	font-weight: bold;
    font-size: 1.2em;
  	user-select: none;
}

.disabled-linkSpecial a{
    pointer-events: none;
}

.torn-style-1 {
clip-path: polygon(1% 0, 50% 30%, 10% 70%, 0 30%);
      box-shadow: -5px 5px 10px rgba(0, 0, 0, 0.5), 
                -5px -5px 10px rgba(255, 255, 255, 0.5) inset;
}

.torn-style-2 {
clip-path: polygon(100% 0, 30% 40%, 10% 70%, 0 30%);
}

.torn-style-3 {
clip-path: polygon(80% 0, 30% 80%, 30% 50%, 0 30%);
}

.torn-style-4 {
clip-path: polygon(50% 0, 30% 40%, 30% 50%, 0 10%);
}

.torn-style-5 {
clip-path: polygon(50% 0, 100% 80%, 50% 50%, 0 10%);
}

.torn-style-6 {
clip-path: polygon(70% 0, 70% 10%, 50% 80%, 0 70%);
}

.torn-style-7 {
clip-path: polygon(30% 10%, 50% 40%, 50% 70%, 0 70%);
}

.torn-style-8 {
clip-path: polygon(78% 100%, 44% 43%, 44% 43%, 0 70%);
}

.torn-style-9 {
clip-path: polygon(77% 1%, 67% 44%, 50% 100%, 0 50%);
}
.torn-style-10 {
clip-path: polygon(20% 1%, 67% 44%, 50% 100%, 30% 50%);
}

.torn-effect {
    filter: grayscale(100%);
}

.rescueClueStyle {
	width: 10px;
  	height: 10px;
}

.furnitureSearch a{
	width: 2.5vw;
}

.furnitureSearch img{
	max-width: 40%;
  	height: auto;
    background-color: rgba(169, 169, 169, 0.5);
}

.furnitureSearch {
	display: flex;
    justify-content: center;
    gap: 10%;
  	margin-left: -20%;
}	
.downPointer {
    position: fixed;
    right: 2%;
  	bottom:2%;
  	z-index: 10;
  	width: 50px;
    height: 50px;
    border-radius: 30%;
}

.upPointer {
    position: fixed;
  	top: 2%;
    right: 2%;
  	transform: rotate(180deg);
  	z-index: 10;
    width: 50px;
    height: 50px;
    border-radius: 30%;
}

.hideRescueHouse {
	display: none;
}

.contactsImages {
  border: 4px solid #fff;
  border-radius: 8px;
  margin: 5px;
  max-width: 100%;
}

.addGap5 {
	gap: 5%;
}

.hauntedhouse {
  	background-attachment: fixed;
	overflow: hidden;
  	height: 100vh;
  	background-position: center;
}

.noreturn {
	background-attachment: fixed;
}

.highlighted-furniture {
    border: 2px solid pink; 
}

.fadeInScale {
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 3s ease, transform 1s ease;
}
.fadeInScaleFool {
	opacity: 0;
    transition: opacity 1s ease;
}
.tarotCardsShow {
    opacity: 1;
    transform: scale(1);
}

.smooth-transition {
    transition: background-image 0.9s ease;
}

.hideMainScreen {
	color: rgba(255, 255, 255, 0.8);
}

.debug {
	font-size: 0.8em;
	font-weight: bold;
}

.furnitureSearch span {
  display: inline-block;
}

.furnitureSearch span a {
  display: block; 
}

.furnitureSearch span img {
  display: block; 
  max-width: 100%;
  height: auto;
}

.highlighted-furnitureDetector {
    border: 2px solid green; 
}


#ui-bar-body {
	overflow-x:hidden;
}

