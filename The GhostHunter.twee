$(document).on(':passagestart', function (ev) {
	if (!ev.passage.tags.includes('noreturn')) {
		State.variables.return = ev.passage.name;
	}
});





:: StoryStylesheet [stylesheet]
@import url('https://fonts.googleapis.com/css2?family=Creepster&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Amatic+SC&family=Creepster&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Cormorant&display=swap');
@import url('https://fonts.googleapis.com/css2?family=Kode+Mono:wght@400..700&display=swap');


/* hovertip v2.0 - Start */
.hoverTip {
	display: inline-block;
	top: 4px;
	border-width: 0px;
   
}
.hoverTipTxt {
	position: relative;
	vertical-align: text-bottom;
	line-height: initial;
}
.hoverTipTxt .hoverBox {
	position: absolute;
	visibility: hidden;
}
.hoverTipTxt:hover .hoverBox, .hoverTipTxt:focus .hoverBox {
	visibility: visible;
}
.hoverBox {
	padding: 3px 10px;
	width: intrinsic;  /* Safari/WebKit uses a non-standard name */
	width: -webkit-max-content;  /* Chrome */
	width: -moz-max-content;  /* Firefox/Gecko */
	width: max-content;
	max-width: 330px;
	line-height: initial;
	text-align: left;
	color: white;
	background-color: black;
	border: #7f7f7f solid 2px;
	-webkit-border-radius: 6px;
	   -moz-border-radius: 6px;
	        border-radius: 6px;
	-webkit-box-shadow: 0px 0px 12px 2px rgba(0, 0, 0, 0.75);
	   -moz-box-shadow: 0px 0px 12px 2px rgba(0, 0, 0, 0.75);
	        box-shadow: 0px 0px 12px 2px rgba(0, 0, 0, 0.75);
	z-index: 100;
}
.hoverTail::after {
	content: "";
	position: absolute;
	top: 100%;  /* At the bottom of the tooltip */
	left: 50%;
	margin-left: -5px;
	border-width: 8px;
	border-style: solid;
	border-color: #7f7f7f transparent transparent transparent;
	z-index: 100;
}
.hoverBox a {
	-webkit-transition-duration: unset;
	   -moz-transition-duration: unset;
	     -o-transition-duration: unset;
	        transition-duration: unset;
}
#ui-bar .hoverBox {
	max-width: 230px;
}
/* hovertip v2.0 - End */


body.ghoststreet {
  background-image: url('assets/img/ghoststreet.jpg');
  background-size: cover;
}

body.city {
  background-image: url('assets/img/city.jpg');
  background-size: cover;
}

.deliverywrapper {
  	display: flex;
    flex-direction: row;
  	gap: 5%;
}

.itemAvailableOne{
	
}

.icontext {
  font-family: 'Creepster', cursive;
  font-size: 25px;
}

.icontextcity {
	font-family: 'Amatic SC', sans-serif;
	font-size: 25px;
  	font-weight: bold;
}

.icontextcity a {
	text-decoration: none;
}

.icontext a {
	color:#8FBC8F;
  	text-decoration: none;
}

.icontextdelivery {
	font-family: 'Cormorant', serif;
  	font-size: 21px;
  	
}

.icontextdelivery a {
  	color:#643069;
  	text-decoration: none;
}

.icontextdelivery a:hover {
  	transition: all .4s ease;
	-webkit-transition: all .4s ease;
    color: #d01de0;
}

.icontext a:hover {
	transition: all .4s ease;
	-webkit-transition: all .4s ease;
    color: #2E8B57;
}

.icon {
	max-width: 50%;
	height: auto;
  	border-radius: 30%;
}

.iconsOnMap {
	max-width: 50%;
    max-height: 90%;
  	border-radius: 30%;
}

.iconPx {
	width: 90px;
    height: 90px;
  	border-radius: 30%;
}

#endShift {
	
}

.btnendshift {
	position: fixed;
  	top: 2%;
  	right: 2%;
}

.btnendcolor {
  	background-color: #ff6666;
	color: #333333;
  	padding: 15px;
  	border-radius: 5px;
  	box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
  	font-weight: bold;
}

.clickable {
	cursor: pointer;
}

.clickable:hover {
	transition: all .4s ease;
	-webkit-transition: all .4s ease;
    color: #595959;
  	background-color: #ff9999;
}

.flexwrapper {
	display: flex;
  	flex-wrap: wrap;
  	align-content: space-around;
  	height: 100%;
  	row-gap: 10px;
}

.housecard {
  	width: 16.5%;
  	text-align:center;
  	z-index: 2;
  	line-height: 1.3;
}

